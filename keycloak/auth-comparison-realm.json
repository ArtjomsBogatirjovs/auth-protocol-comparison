{
  "realm": "auth-comparison",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "components": {
    "org.keycloak.keys.KeyProvider": [
      {
        "name": "fixed-saml-rsa",
        "providerId": "rsa",
        "subComponents": {},
        "config": {
          "priority": ["100"],
          "enabled": ["true"],
          "active": ["true"],
          "privateKey": [""],
          "certificate": [""]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "auth-comparison-app-oidc",
      "name": "Auth Comparison OIDC App",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "auth-comparison-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/auth/oidc/callback"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*"
      }
    },
    {
      "clientId": "auth-comparison-app-saml",
      "name": "Auth Comparison SAML App",
      "enabled": true,
      "protocol": "saml",
      "redirectUris": [
        "http://localhost:3000/auth/saml/callback"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "saml.assertion.signature": "true",
        "saml.client.signature": "false",
        "saml.force.post.binding": "true",
        "saml.server.signature": "true",
        "saml_name_id_format": "username",
        "saml.authnstatement": "true",
        "saml.onetimeuse.condition": "false",
        "saml_signature_canonicalization_method": "http://www.w3.org/2001/10/xml-exc-c14n#",
        "saml_single_logout_service_url_post": "http://localhost:3000/logout/saml/callback",
        "saml_single_logout_service_url_redirect": "http://localhost:3000/logout/saml/callback",
        "saml_single_logout_service_url_soap": "http://localhost:3000/logout/saml/callback"
      }
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "email": "testuser@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "testpass",
          "temporary": false
        }
      ]
    }
  ]
}